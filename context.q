        "content": {
          "Prompt": {
            "prompt": "the text size is wrong i think\n\ninstallHook.js:1 using deprecated parameters for the initialization function; pass a single object instead\noverrideMethod @ installHook.js:1\n__wbg_init @ drafftink_app.js:3182\nrun @ (index):118\nawait in run\n(anonymous) @ (index):142\ndrafftink_app.js:1153 Starting DrafftInk (WASM)\ndrafftink_app.js:1153 Creating window...\ndrafftink_app.js:1153 Canvas created: 1183x897 (physical: 2366x1794, dpr: 2)\ndrafftink_app.js:1153 Window created, initializing renderer...\ndrafftink_app.js:1153 Surface size: 1280x800\ndrafftink_app.js:1153 Creating surface asynchronously...\ndrafftink_app.js:1153 Surface created successfully\ndrafftink_app.js:1153 DrafftInk initialized - 2366x1794\ndrafftink_app.js:1153 Keyboard shortcuts: V=Select, H=Pan, R=Rectangle, E=Ellipse, L=Line, A=Arrow, P=Pen\ndrafftink_app.js:1153 Document loaded from IndexedDB: empty\ndrafftink_app.js:1153 Entered text edit mode for new text shape a23bf81b-90c2-4e53-b72f-7ed7e2d84de4\ndrafftink_app.js:1153 exit_text_edit: anchor=Some((530.1385788690476, 402.88783482142856)), size=(55.0, 24.0), content='Enter', pos=(530.1385788690476, 402.88783482142856), rot=0.000\ndrafftink_app.js:1153 Entered text edit mode for shape a23bf81b-90c2-4e53-b72f-7ed7e2d84de4, content: 'Enter'\ndrafftink_app.js:1153 exit_text_edit: anchor=Some((527.9155461269374, 420.9936721164112)), size=(45.6, 24.0), content='Enter', pos=(530.1385788690476, 402.88783482142856), rot=-0.724\ndrafftink_app.js:1153 Entered text edit mode for shape a23bf81b-90c2-4e53-b72f-7ed7e2d84de4, content: 'Enter'\ndrafftink_app.js:1153 exit_text_edit: anchor=Some((527.9155461269374, 420.9936721164112)), size=(45.6, 24.0), content='EnterNew', pos=(530.1385788690476, 402.88783482142856), rot=-0.724\n"
          }
        },
        "timestamp": "2025-12-31T10:58:13.644291647Z",
        "images": null
