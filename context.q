        "content": {
          "ToolUseResults": {
            "tool_use_results": [
              {
                "tool_use_id": "tooluse_tIwZMbnHSmiawsZwGrMxaA",
                "content": [
                  {
                    "Json": {
                      "exit_status": "0",
                      "stdout": "1745:                                text.content = new_text;\n3435:                                            text.content = new_text;\n3444:                                            text.content = new_text;\n3458:                                            text.content = new_text;",
