                "new_str": "    /// Shape ID being edited (for text editing).\n    pub editing_text: Option<ShapeId>,\n    /// Original top-left handle position when editing started (for preserving visual position on rotated text).\n    pub text_edit_anchor: Option<Point>,\n    /// Original rotation when editing started.\n    text_edit_rotation: f64,\n    /// Original bounds size when editing started.\n    text_edit_size: Option<(f64, f64)>,",
                "old_str": "    /// Shape ID being edited (for text editing).\n    pub editing_text: Option<ShapeId>,\n    /// Original top-left handle position when editing started (for preserving visual position on rotated text).\n    pub text_edit_anchor: Option<Point>,\n    /// Original rotation when editing started.\n    text_edit_rotation: f64,",
