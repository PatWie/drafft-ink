        },
        "content": {
          "CancelledToolUses": {
            "prompt": "DURING editing it stays, after pressing ESC to exit text edit mode, some bounds are recompute or something else and the final text slight shifts. I can confirm the new anchor is not in the same place as the old anchor",
            "tool_use_results": [
              {
                "tool_use_id": "tooluse_ajU3Zi3eSbaPKtFt4Py4sQ",
                "content": [
                  {
                    "Text": "Tool use was cancelled by the user"
