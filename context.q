              "name": "fs_write",
              "orig_name": "fs_write",
              "args": {
                "command": "str_replace",
                "new_str": "                        // Update cursor blinking\n                        if let Some(edit_state) = &mut state.text_edit_state {\n                            edit_state.cursor_blink();\n                            state.shape_renderer.render_text_editing(text, edit_state, camera_transform, state.event_handler.text_edit_anchor);\n                        }\n                    }\n                }",
                "old_str": "                        // Update cursor blinking\n                        if let Some(edit_state) = &mut state.text_edit_state {\n                            edit_state.cursor_blink();\n                            state.shape_renderer.render_text_editing(text, edit_state, camera_transform, state.event_handler.text_edit_anchor);\n                        }\n                        \n                        // DEBUG: Visualize the anchor point that should stay fixed\n                        if let Some(anchor) = state.event_handler.text_edit_anchor {\n                            state.shape_renderer.render_debug_anchor(anchor, camera_transform);\n                        }\n                    }\n                }",
                "path": "/local/home/patwie/git/github.com/patwie/drafft-ink/crates/drafftink-app/src/app.rs",
                "summary": "Remove debug anchor visualization"
              },
