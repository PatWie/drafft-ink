                "content": [
                  {
                    "Text": "                            let mut edit_state = TextEditState::new(&text.content, text.font_size as f32);\n                            edit_state.cursor_reset();\n                            state.text_edit_state = Some(edit_state);\n                        }\n                        \n                        // Update cursor blinking\n                        if let Some(edit_state) = &mut state.text_edit_state {\n                            edit_state.cursor_blink();\n                            state.shape_renderer.render_text_editing(text, edit_state, camera_transform);\n                        }\n                        \n                        // DEBUG: Visualize the anchor point that should stay fixed\n                        if let Some(anchor) = state.event_handler.text_edit_anchor {\n                            state.shape_renderer.render_debug_anchor(anchor, camera_transform);\n                        }\n                    }\n                }\n                \n                // Render remote peer cursors\n                {\n                    let camera = &state.canvas.camera;"
                  }
                ],
                "status": "Success"
              }
            ]
          }
        },
